@model WhiteLagoon.Domain.Entities.Booking

<div class="container pt-4 mt-5 mb-5">
    <div class="card bg-darker border-secondary shadow-lg rounded-4 overflow-hidden">
        <form method="post">
            <input asp-for="Id" hidden />
            <input asp-for="VillaId" hidden />
            <input asp-for="UserId" hidden />

            <div class="card-header bg-dark border-bottom border-secondary py-3">
                <div class="row align-items-center">
                    <div class="col-6">
                        <h3 class="text-light mb-0"><i class="bi bi-card-list me-2 text-primary"></i>Booking #@Model.Id</h3>
                    </div>
                    <div class="col-6 text-end">
                        <a asp-action="Index" asp-route-status="approved" class="btn btn-outline-secondary btn-sm rounded-pill">
                            <i class="bi bi-arrow-left me-1"></i> Back to Bookings
                        </a>
                        <button type="submit" asp-action="CancelBooking" class="btn btn-outline-danger btn-sm rounded-pill ms-2">
                            <i class="bi bi-x-circle me-1"></i> Cancel Booking
                        </button>
                    </div>
                </div>
            </div>

            <div class="card-body p-4 p-lg-5">
                <div class="row g-5">
                    <div class="col-lg-5">
                        <div class="pe-lg-4 border-end border-secondary h-100">
                            <h4 class="text-primary mb-4">Villa Details</h4>
                            <partial name="_VillaDetail" model="@Model.Villa" />
                        </div>
                    </div>

                    <div class="col-lg-7">
                        <h4 class="text-primary mb-4">Enter Booking Details</h4>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="Name" class="form-label text-warning small fw-bold text-uppercase">Name</label>
                                <input asp-for="Name" class="form-control bg-dark border-secondary text-light" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Phone" class="form-label text-warning small fw-bold text-uppercase">Phone</label>
                                <input asp-for="Phone" class="form-control bg-dark border-secondary text-light" />
                            </div>
                            <div class="col-12">
                                <label asp-for="Email" class="form-label text-warning small fw-bold text-uppercase">Email</label>
                                <input asp-for="Email" class="form-control bg-dark border-secondary text-light" />
                            </div>

                            <hr class="border-secondary my-3" />

                            <div class="col-md-6">
                                <label class="form-label text-warning small fw-bold text-uppercase">Status</label>
                                <input disabled asp-for="Status" class="form-control bg-darker border-secondary text-light-50" readonly />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-warning small fw-bold text-uppercase">Booking Date</label>
                                <input disabled value="@Model.BookingDate.ToString("yyyy-MM-dd HH:mm")" class="form-control bg-darker border-secondary text-light-50" readonly />
                            </div>
                            
                            @if (Model.IsPaymentSuccessful && User.IsInRole(SD.Role_Admin))
                            {
                                <div class="col-12">
                                    <label class="form-label text-warning small fw-bold text-uppercase">Paddle Transaction Id</label>
                                    <input disabled asp-for="PaddleTransactionId" class="form-control bg-darker border-secondary text-light-50" readonly />
                                </div>
                            
                                <div class="col-md-6">
                                    <label class="form-label text-warning small fw-bold text-uppercase">Payment Date</label>
                                    <input disabled value="@(Model.PaymentDate > DateTimeOffset.MinValue ? Model.PaymentDate.ToString("yyyy-MM-dd") : "Not Paid")" 
                                           class="form-control bg-darker border-secondary text-light-50" readonly />
                                </div>
                            }
                        </div>

                        <div class="mt-5 d-grid gap-3">
                            @if (User.IsInRole(SD.Role_Admin))
                            {
                                @if (Model.Status == SD.StatusApproved)
                                {
                                    <button type="submit" asp-action="CheckIn" class="btn btn-warning py-3 fw-bold text-dark">
                                        <i class="bi bi-door-open-fill me-2"></i> Check In
                                    </button>
                                }
                                
                                @if (Model.Status == SD.StatusCheckedIn)
                                {
                                    <button type="submit" asp-action="CheckOut" class="btn btn-success py-3 fw-bold">
                                        <i class="bi bi-box-arrow-right me-2"></i> Check Out / Complete Booking
                                    </button>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>